{
  "buildCommand": "ROOT=$(git rev-parse --show-toplevel) && npm --prefix $ROOT/packages/types run build && npm --prefix $ROOT/apps/web run build",
  "outputDirectory": ".next",
  "installCommand": "npm install --legacy-peer-deps",
  "devCommand": "npm run dev:web",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://bloom-ai-mqrb.onrender.com/api/:path*"
    },
    {
      "source": "/health",
      "destination": "https://bloom-ai-mqrb.onrender.com/health"
    }
  ]
}
