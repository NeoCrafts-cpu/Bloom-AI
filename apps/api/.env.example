# Bloom AI API Environment Variables
# Copy this file to .env and fill in your keys

# ─── Server ────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
WEB_URL=http://localhost:3000

# ─── SoSoValue Terminal API ─────────────────────────────────────────────────
# Get your key at https://openapi.sosovalue.com
SOSOVALUE_API_KEY=

# ─── SoDEX On-Chain DEX ─────────────────────────────────────────────────────
# Registered SoDEX API key name sent in X-API-Key (not the address/private key)
SODEX_API_KEY_NAME=
# Optional API key public address for nonce namespacing; derived from private key if omitted
SODEX_API_KEY_ADDRESS=
# Private key for the registered API key, used locally for EIP-712 order signing (NEVER commit real keys)
SODEX_API_PRIVATE_KEY=
# testnet | mainnet (sets chain + gateway defaults)
SODEX_NETWORK=testnet
# Testnet=138565, Mainnet=286623
SODEX_CHAIN_ID=138565
SODEX_ENABLE_PERPS_COPY=0
SODEX_ENABLE_TWAP=0
# Optional Redis for nonces/cache (falls back to memory)
REDIS_URL=redis://localhost:6379
# Optional Coinglass key (Binance public funding used as fallback)
COINGLASS_API_KEY=

# ─── OpenRouter LLM ─────────────────────────────────────────────────────────
# Get your key at https://openrouter.ai
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# ─── External Data APIs ─────────────────────────────────────────────────────
# CryptoPanic news feed — get free key at https://cryptopanic.com/developers/api/
CRYPTOPANIC_API_KEY=

# ─── Agent Configuration ────────────────────────────────────────────────────
# Journalist runs every 10 minutes by default
JOURNALIST_INTERVAL_MS=600000
# Sentinel risk limits
SENTINEL_MAX_ORDER_USD=10000
SENTINEL_MAX_DAILY_USD=50000
SENTINEL_MAX_SLIPPAGE_BPS=100
# Hard-block when high-importance macro event is within ±N hours (SoSoValue calendar)
SENTINEL_MACRO_GATE_HOURS=12
