# Bloom AI Web — Environment Variables
# Copy this file to .env.local

# URL of the Bloom AI API server
# Development: http://localhost:4000
# Production: https://your-api.up.railway.app
NEXT_PUBLIC_API_URL=http://localhost:4000

# Optional: enable direct SoDEX WebSocket in order book (default REST-only to avoid console noise)
# NEXT_PUBLIC_SODEX_WS_ENABLED=true
# NEXT_PUBLIC_SODEX_WS_SPOT=wss://testnet-gw.sodex.dev/ws/spot
